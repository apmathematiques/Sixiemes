<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Exercice interactif</title>
<style>
:root{
  --accent:#2F7F89;
  --success:#C8FE53;
  --success-ink:#294100;
  --hint:#EBF4FF;
  --hint-ink:#2C5282;
  --error:#FFF1EF;
  --error-ink:#8D2F24;
  --error-border:#F3A89F;
  --ink:#171717;
  --muted:#666;
}
*{box-sizing:border-box}
html,body{margin:0;width:100%;height:100%}
body{
  font-family:Arial,sans-serif;
  background:transparent;
  color:var(--ink);
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
}
button,input{font:inherit}
#app{width:min(96vw,1020px);height:min(96vh,700px);padding:14px}
.hud{
  display:flex;
  justify-content:space-between;
  gap:12px;
  background:rgba(255,255,255,.88);
  border-radius:14px;
  padding:10px 16px;
  margin-bottom:12px;
  font-size:clamp(15px,2vw,21px);
  font-weight:bold;
  box-shadow:0 5px 16px rgba(0,0,0,.05)
}
.card{
  background:rgba(255,255,255,.94);
  border-radius:24px;
  min-height:calc(100% - 56px);
  padding:clamp(12px,2.1vw,22px);
  box-shadow:0 10px 25px rgba(0,0,0,.08);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:11px;
  text-align:center
}
.question{font-size:clamp(20px,2.7vw,29px);margin:0}
.figure-wrap{
  width:min(100%,760px);
  min-height:175px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:rgba(255,255,255,.72);
  border:3px solid #ECECEC;
  border-radius:22px;
  padding:6px 10px;
}
.figure-wrap svg{width:100%;max-width:600px;height:auto;display:block}
.answer-label{font-size:clamp(17px,2.1vw,22px);font-weight:bold}
.fraction-input{
  display:grid;
  grid-template-rows:auto 4px auto;
  gap:6px;
  align-items:center;
  justify-items:center
}
.fraction-input input{
  width:110px;
  height:48px;
  border:3px solid #DDD;
  border-radius:13px;
  text-align:center;
  font-size:clamp(22px,4vw,32px);
  font-weight:800;
  outline:none;
  background:white
}
.fraction-input input:focus{
  border-color:var(--accent);
  box-shadow:0 0 0 4px rgba(47,127,137,.12)
}
.bar{width:130px;height:4px;background:#111;border-radius:3px}
.help{font-size:clamp(13px,1.6vw,16px);color:var(--muted)}
.actions{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.action{
  border:0;
  border-radius:15px;
  padding:10px 22px;
  background:var(--accent);
  color:white;
  font-size:clamp(16px,1.9vw,20px);
  font-weight:bold;
  cursor:pointer;
  box-shadow:0 4px 0 rgba(0,0,0,.15);
  min-width:190px
}
.action:disabled{opacity:.55;cursor:default}
#nextBtn{display:none}
#feedback{
  display:none;
  width:min(100%,760px);
  border-radius:15px;
  padding:10px 14px;
  font-size:clamp(14px,1.8vw,18px);
  line-height:1.38
}
#feedback.success{
  display:block;
  background:var(--success);
  color:var(--success-ink);
  font-weight:bold
}
#feedback.hint{
  display:block;
  background:var(--hint);
  color:var(--hint-ink);
  border:2px solid #D0E3F7
}
#feedback.error{
  display:block;
  background:var(--error);
  color:var(--error-ink);
  border:2px solid var(--error-border)
}
#final{
  display:none;
  height:100%;
  background:rgba(255,255,255,.96);
  border-radius:24px;
  padding:34px;
  text-align:center;
  box-shadow:0 10px 25px rgba(0,0,0,.08)
}
#finalInner{
  height:100%;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  gap:18px
}
#final h1{margin:0;font-size:clamp(28px,4vw,42px)}
#finalScore{font-size:clamp(54px,10vw,90px);font-weight:900;color:var(--accent)}
#advice{font-size:clamp(20px,3vw,28px);max-width:760px;line-height:1.35}
#restartBtn{display:inline-block}
@media(max-width:620px){
  #app{padding:8px}
  .card{gap:8px;padding:9px}
  .figure-wrap{min-height:155px}
}
@media(max-height:650px){
  .card{gap:7px;padding:7px}
  .figure-wrap{min-height:135px}
  .fraction-input input{height:42px}
}
</style>
</head>
<body>
<div id="app">
  <div id="game">
    <div class="hud">
      <span id="progress"></span>
      <span id="score"></span>
    </div>

    <div class="card">
      <p class="question">Quelle est l’abscisse du point A&nbsp;?</p>

      <div class="figure-wrap" id="figureWrap"></div>

      <div class="answer-label">A a pour abscisse :</div>

      <div class="fraction-input" aria-label="Saisir l'abscisse">
        <input id="numInput" inputmode="numeric" pattern="[0-9]*" maxlength="3" aria-label="Numérateur">
        <div class="bar"></div>
        <input id="denInput" inputmode="numeric" pattern="[0-9]*" maxlength="3" aria-label="Dénominateur">
      </div>

      <div class="help">Pour un entier, laisse la case du bas vide.</div>

      <div id="feedback" role="status"></div>

      <div class="actions">
        <button class="action" id="validateBtn">Valider</button>
        <button class="action" id="nextBtn">Question suivante</button>
      </div>
    </div>
  </div>

  <div id="final">
    <div id="finalInner">
      <h1>Bilan</h1>
      <div id="finalScore"></div>
      <div id="advice"></div>
      <button class="action" id="restartBtn">Recommencer</button>
    </div>
  </div>
</div>

<script>
(function(){
"use strict";

var current=0,score=0,attempts=0,resolved=false,questions=[];

function el(id){return document.getElementById(id)}
function rand(a,b){return Math.floor(Math.random()*(b-a+1))+a}
function choice(a){return a[rand(0,a.length-1)]}
function gcd(a,b){while(b){var t=b;b=a%b;a=t}return Math.abs(a)}
function sameFraction(a,b,c,d){return b!==0 && d!==0 && a*d===c*b}

function makeQuestion(mode){
  var fractional=Math.random()<0.65;
  var stepNum,stepDen;

  if(fractional){
    stepNum=1;
    stepDen=rand(2,8);
  }else{
    stepNum=rand(1,4);
    stepDen=1;
  }

  var firstLabelIndex;
  if(mode==="zeroOne" || mode==="zeroOther"){
    firstLabelIndex=0;
  }else{
    firstLabelIndex=rand(2,5);
  }
  var labelledGap;
  var firstLabelValue;
  var secondLabelValue;

  if(mode==="zeroOne"){
    firstLabelValue=0;
    secondLabelValue=1;
    labelledGap=stepDen;
    stepNum=1;
  }else if(mode==="zeroOther"){
    firstLabelValue=0;
    secondLabelValue=rand(2,10);

    if(fractional){
      labelledGap=secondLabelValue*stepDen;
      if(labelledGap>10){
        stepDen=choice([2,3,4,5]);
        labelledGap=secondLabelValue*stepDen;
      }
    }else{
      stepNum=choice([1,2]);
      stepDen=1;
      labelledGap=secondLabelValue/stepNum;
      if(!Number.isInteger(labelledGap) || labelledGap<2 || labelledGap>10){
        stepNum=1;
        labelledGap=secondLabelValue;
      }
    }
  }else{
    firstLabelValue=rand(1,7);

    if(fractional){
      labelledGap=stepDen;
      secondLabelValue=firstLabelValue+1;
    }else{
      labelledGap=rand(2,5);
      secondLabelValue=firstLabelValue+labelledGap*stepNum;
    }
  }

  var secondLabelIndex=firstLabelIndex+labelledGap;
  var totalIntervals=Math.max(secondLabelIndex+rand(2,4),10);
  totalIntervals=Math.min(totalIntervals,18);

  if(secondLabelIndex>totalIntervals-2){
    totalIntervals=secondLabelIndex+2;
  }

  var possiblePointIndices=[];
  for(var i=0;i<=totalIntervals;i++){
    if(i!==firstLabelIndex && i!==secondLabelIndex){
      var valueNum=firstLabelValue*stepDen+(i-firstLabelIndex)*stepNum;
      if(valueNum>=0)possiblePointIndices.push(i);
    }
  }

  var pointIndex=choice(possiblePointIndices);
  var pointNum=firstLabelValue*stepDen+(pointIndex-firstLabelIndex)*stepNum;
  var pointDen=stepDen;
  var g=gcd(pointNum,pointDen);
  pointNum/=g;
  pointDen/=g;

  return{
    stepNum:stepNum,
    stepDen:stepDen,
    firstLabelIndex:firstLabelIndex,
    secondLabelIndex:secondLabelIndex,
    firstLabelValue:firstLabelValue,
    secondLabelValue:secondLabelValue,
    totalIntervals:totalIntervals,
    pointIndex:pointIndex,
    pointNum:pointNum,
    pointDen:pointDen
  };
}

function buildQuestions(){
  var modes=[
    "zeroOne","zeroOne","zeroOne",
    "zeroOther","zeroOther","zeroOther",
    "nonZero","nonZero","nonZero","nonZero"
  ];
  for(var i=modes.length-1;i>0;i--){
    var j=rand(0,i),t=modes[i];modes[i]=modes[j];modes[j]=t;
  }

  var out=[];
  var seen={};

  modes.forEach(function(mode){
    var q,key;
    do{
      q=makeQuestion(mode);
      key=[
        mode,q.stepNum,q.stepDen,q.firstLabelValue,
        q.secondLabelValue,q.firstLabelIndex,
        q.secondLabelIndex,q.pointIndex
      ].join("-");
    }while(seen[key]);

    seen[key]=true;
    out.push(q);
  });

  return out;
}

function formatNumber(n){
  return Number.isInteger(n)?String(n):String(n).replace(".",",");
}

function formatFraction(n,d){
  return d===1?String(n):n+"/"+d;
}

function drawAxis(q){
  var x0=40,x1=640,y=112,arrowEnd=675;
  var step=(x1-x0)/q.totalIntervals;
  var parts=[];

  var lineStart=(q.firstLabelValue===0 && q.firstLabelIndex===0)?x0:(x0-20);
  parts.push(`<line x1="${lineStart}" y1="${y}" x2="${arrowEnd}" y2="${y}" stroke="#202020" stroke-width="5" stroke-linecap="round"/>`);
  parts.push(`<path d="M ${arrowEnd-16} ${y-11} L ${arrowEnd} ${y} L ${arrowEnd-16} ${y+11}" fill="none" stroke="#202020" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/>`);

  for(var i=0;i<=q.totalIntervals;i++){
    var x=x0+i*step;
    parts.push(`<line x1="${x}" y1="${y-15}" x2="${x}" y2="${y+15}" stroke="#202020" stroke-width="4"/>`);
  }

  var xA=x0+q.pointIndex*step;
  parts.push(`<line x1="${xA-8}" y1="${y-8}" x2="${xA+8}" y2="${y+8}" stroke="#D84635" stroke-width="5" stroke-linecap="round"/>`);
  parts.push(`<line x1="${xA-8}" y1="${y+8}" x2="${xA+8}" y2="${y-8}" stroke="#D84635" stroke-width="5" stroke-linecap="round"/>`);
  parts.push(`<text x="${xA}" y="${y-28}" text-anchor="middle" font-size="25" font-weight="800" fill="#A63225">A</text>`);

  var xL1=x0+q.firstLabelIndex*step;
  var xL2=x0+q.secondLabelIndex*step;

  parts.push(`<text x="${xL1}" y="${y+48}" text-anchor="middle" font-size="26" font-weight="700" fill="#171717">${formatNumber(q.firstLabelValue)}</text>`);
  parts.push(`<text x="${xL2}" y="${y+48}" text-anchor="middle" font-size="26" font-weight="700" fill="#171717">${formatNumber(q.secondLabelValue)}</text>`);

  return `<svg viewBox="0 0 700 205" role="img" aria-label="Demi-droite graduée avec un point A">${parts.join("")}</svg>`;
}

function updateHud(){
  el("progress").textContent="Question "+(current+1)+" / 10";
  el("score").textContent="Score : "+String(score).replace(".",",")+" / 10";
}

function showQuestion(){
  attempts=0;
  resolved=false;
  updateHud();

  var q=questions[current];
  el("figureWrap").innerHTML=drawAxis(q);

  el("numInput").value="";
  el("denInput").value="";
  el("numInput").disabled=false;
  el("denInput").disabled=false;

  el("feedback").className="";
  el("feedback").style.display="none";
  el("feedback").textContent="";

  el("validateBtn").disabled=false;
  el("validateBtn").style.display="inline-block";
  el("nextBtn").style.display="none";

  setTimeout(function(){el("numInput").focus()},0);
}

function readAnswer(){
  var numText=el("numInput").value.trim();
  var denText=el("denInput").value.trim();

  if(numText==="") return null;

  var a=Number(numText);
  var b=denText===""?1:Number(denText);

  if(!Number.isInteger(a)||!Number.isInteger(b)||a<0||b<=0) return null;
  return {num:a,den:b};
}

function validate(){
  if(resolved)return;

  var answer=readAnswer();
  var fb=el("feedback");

  if(!answer){
    fb.className="error";
    fb.textContent="Saisis un entier ou une fraction valide.";
    fb.style.display="block";
    return;
  }

  var q=questions[current];
  var ok=sameFraction(answer.num,answer.den,q.pointNum,q.pointDen);

  if(ok){
    resolved=true;
    if(attempts===0){
      score+=1;
      fb.className="success";
      fb.textContent="Bravo ! Tu as correctement lu l’abscisse du point A.";
    }else{
      score+=0.5;
      fb.className="success";
      fb.textContent="Bonne réponse ! Tu gagnes 0,5 point au deuxième essai.";
    }
    finish();
    return;
  }

  attempts++;

  if(attempts===1){
    fb.className="hint";
    fb.textContent="Indice : détermine d’abord le pas, puis compte les intervalles entre une graduation numérotée et le point A.";
    fb.style.display="block";
    el("numInput").select();
  }else{
    resolved=true;
    fb.className="error";
    fb.innerHTML="Correction : le point A a pour abscisse <strong>"+formatFraction(q.pointNum,q.pointDen)+"</strong>.";
    finish();
  }
}

function finish(){
  updateHud();
  el("numInput").disabled=true;
  el("denInput").disabled=true;
  el("validateBtn").disabled=true;
  el("validateBtn").style.display="none";
  el("nextBtn").style.display="inline-block";
  el("feedback").style.display="block";
}

function next(){
  if(current<9){
    current++;
    showQuestion();
  }else{
    showFinal();
  }
}

function showFinal(){
  el("game").style.display="none";
  el("final").style.display="block";
  el("finalScore").textContent=String(score).replace(".",",")+"/10";

  var advice=score<=4.5
    ?"Revois le pas et le comptage des intervalles, puis recommence."
    :score<=7.5
    ?"C’est en bonne voie ! Pense à partir d’une graduation numérotée."
    :score<=9.5
    ?"Très bon travail !"
    :"Excellent ! Tu sais lire l’abscisse d’un point.";

  el("advice").textContent=advice;
}

function restart(){
  current=0;
  score=0;
  questions=buildQuestions();

  el("final").style.display="none";
  el("game").style.display="block";

  showQuestion();
}

el("validateBtn").onclick=validate;
el("nextBtn").onclick=next;
el("restartBtn").onclick=restart;

el("numInput").addEventListener("keydown",function(e){
  if(e.key==="Enter") el("denInput").focus();
});
el("denInput").addEventListener("keydown",function(e){
  if(e.key==="Enter") validate();
});

restart();
})();
</script>
</body>
</html>
